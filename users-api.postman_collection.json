          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"name\": \"Anderson Cruz\",\n  \"email\": \"anderson@email.com\",\n  \"age\": 28,\n  \"created_at\": \"2026-04-27T12:00:00.000Z\",\n  \"update_at\": \"2026-04-27T12:00:00.000Z\"\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Retorna Content-Type JSON', () => pm.response.to.have.header('Content-Type', /json/));",
                  "const body = pm.response.json();",
                  "pm.test('Retorna id gerado', () => pm.expect(body).to.have.property('id'));",
                  "pm.test('Retorna name correto', () => pm.expect(body.name).to.eql('Anderson Cruz'));",
                  "pm.test('Retorna email correto', () => pm.expect(body.email).to.eql('anderson@email.com'));",
                  "pm.test('Retorna age correto', () => pm.expect(body.age).to.eql(28));",
                  "pm.test('Retorna created_at', () => pm.expect(body).to.have.property('created_at'));",
                  "pm.environment.set('userId', body.id);"
