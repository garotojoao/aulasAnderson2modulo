            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Roupas\",\n  \"status\": \"inativo\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/categories",
              "host": ["{{baseUrl}}"],
              "path": ["categories"]
            },
            "description": "Cria categoria sem description (campo opcional)."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 2,\n  \"name\": \"Roupas\",\n  \"status\": \"inativo\"\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Retorna id', () => pm.expect(body).to.have.property('id'));",
                  "pm.test('Retorna status inativo', () => pm.expect(body.status).to.eql('inativo'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Listar todas as categorias",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/categories",
              "host": ["{{baseUrl}}"],
              "path": ["categories"]
            },
            "description": "Retorna todas as categorias cadastradas."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": 1,\n    \"name\": \"Eletrônicos\",\n    \"status\": \"ativo\"\n  },\n  {\n    \"id\": 2,\n    \"name\": \"Roupas\",\n    \"status\": \"inativo\"\n  }\n]"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Buscar categoria por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["categories", "{{categoryId}}"]
            },
            "description": "Busca uma categoria pelo ID."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"name\": \"Eletrônicos\",\n  \"status\": \"ativo\"\n}"
            },
            {
              "name": "200 OK - não encontrado (null)",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "null"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body) {",
                  "  pm.test('Retorna id', () => pm.expect(body.id).to.be.a('number'));",
                  "  pm.test('Tem campo name', () => pm.expect(body).to.have.property('name'));",
                  "  pm.test('Tem campo status', () => pm.expect(body).to.have.property('status'));",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
